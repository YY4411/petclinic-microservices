      "ignoreDockerVersion": false,
      "kubernetesVersion": "v1.18.12-rancher1-1",
      "ingress": {
        "provider": "nginx",
        "options": {
          "use-forwarded-headers": "true"
        },
        "updateStrategy": {
          "strategy": "RollingUpdate",
          "rollingUpdate": {
            "maxUnavailable": 1
          }
        },
        "httpPort": 80,
        "httpsPort": 443,
        "networkMode": "hostNetwork"
      },
      "clusterName": "local",
      "cloudProvider": {},
      "prefixPath": "/",
      "addonJobTimeout": 30,
      "bastionHost": {},
