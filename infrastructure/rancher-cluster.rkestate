          "serviceClusterIpRange": "10.43.0.0/16"
        },
        "scheduler": {
          "image": "rancher/hyperkube:v1.18.12-rancher1"
        },
        "kubelet": {
          "image": "rancher/hyperkube:v1.18.12-rancher1",
          "clusterDomain": "cluster.local",
          "infraContainerImage": "rancher/pause:3.1",
          "clusterDnsServer": "10.43.0.10"
        },
        "kubeproxy": {
          "image": "rancher/hyperkube:v1.18.12-rancher1"
        }
      },
      "network": {
        "plugin": "canal",
